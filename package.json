{
  "name": "kira-portfolio",
  "version": "1.0.0",
  "description": "KIRA - Thumbnail Designer & Video Editor Portfolio",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build --prefix client",
    "postinstall": "npm install --include=dev --prefix client",
    "server": "nodemon --ignore data/ --ignore client/ server.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
